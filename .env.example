# Anthropic Claude API 키 — https://console.anthropic.com 에서 발급
# 로컬 개발 시: 이 파일을 .env.local 로 복사하고 값을 채우세요 (.env.local은 git에 올라가지 않습니다)
# 배포 시: Netlify 프로젝트 → Site configuration → Environment variables 에 동일한 이름으로 등록하세요
ANTHROPIC_API_KEY=

# (선택) 사용할 모델. 비워두면 기본값 사용
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
